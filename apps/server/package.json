{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently --names Server,Worker -c green,blue  \"bun run server:hot\" \"bun run worker\"",
    "server": "bun run index",
    "server:hot": "bun run --hot index",
    "worker": "bunx @openworkflow/cli worker start"
  },
  "devDependencies": {
    "@openworkflow/cli": "^0.4.4",
    "@types/bun": "latest",
    "@types/mime-types": "^3.0.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "mime-types": "^3.0.2",
    "openworkflow": "^0.9.0",
    "zod": "^4.4.3"
  }
}
